{
  "framework": null,
  "buildCommand": "mkdir -p public && cp -r frontend public/",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/about", "destination": "/frontend/about_advaith_industries/code.html" },
    { "source": "/products", "destination": "/frontend/advaith_product_catalog/code.html" },
    { "source": "/contact", "destination": "/frontend/contact_advaith_industries/code.html" },
    { "source": "/", "destination": "/frontend/advaith_industries_home/code.html" }
  ]
}
